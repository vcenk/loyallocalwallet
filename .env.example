# Local Loyalty Wallet — environment template
# Copy to .env.local and fill in real values. NEVER commit real secrets.
# See docs/env-setup.md for details on each variable.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# Email
RESEND_API_KEY=
EMAIL_FROM="Local Loyalty Wallet <hello@example.com>"

# Apple Wallet (server-side only — never expose to client/Expo)
APPLE_TEAM_ID=
APPLE_PASS_TYPE_IDENTIFIER=
APPLE_PASS_CERT_PATH=
APPLE_PASS_KEY_PATH=
APPLE_PASS_CERT_PASSWORD=
APPLE_WWDR_CERT_PATH=
# A .pass model folder (icon.png/logo.png + base pass.json storeCard). See packages/wallet/README.md
APPLE_PASS_MODEL_PATH=
APPLE_APNS_KEY_ID=
APPLE_APNS_TEAM_ID=
APPLE_APNS_PRIVATE_KEY_PATH=

# Google Wallet (server-side only — never expose to client/Expo)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=
GOOGLE_WALLET_ORIGINS=http://localhost:3000

# Analytics / Monitoring
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Expo staff app (public keys only — NEVER put service role or wallet secrets here)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
