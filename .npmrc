# pnpm settings
# Hoist nothing by default; keep workspace deps explicit and predictable.
# (expo-asset — which Expo's bundler resolves from the app root during
# `expo export:embed` — is declared directly in apps/staff-app so the EAS iOS
# build can find it under pnpm's isolated node_modules. Note: do NOT add
# expo-font/expo-constants there; their @types/react peer leaks React 18 types
# into the React 19 dashboard and breaks its type-check.)
shamefully-hoist=false
strict-peer-dependencies=false
