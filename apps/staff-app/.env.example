# Copy to .env.local. Only EXPO_PUBLIC_* vars are exposed to the app.
# NEVER put the service role key or wallet secrets here.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# The dashboard's API base. On a physical phone use your computer's LAN IP,
# not localhost, e.g. http://192.168.1.50:3000/api
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
