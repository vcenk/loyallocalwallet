{
  "expo": {
    "name": "LoyalLocal Staff",
    "slug": "loyallocal-staff",
    "scheme": "loyallocal-staff",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#fff8f6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.loyallocal.staff",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan customer loyalty cards to add stamps and redeem rewards.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.loyallocal.staff",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LoyalLocal Staff to scan customer loyalty cards."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5b57d099-6912-4e59-a898-587b1473983e"
      }
    },
    "owner": "cenkkara"
  }
}
