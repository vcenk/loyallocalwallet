# Copy to apps/dashboard/.env.local and fill from Supabase Dashboard → Project Settings → API.
# Next.js loads env from this app directory, so these live here (not only at repo root).
# NEVER put real values in this file — it is a committed template. Put them in .env.local (gitignored).
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=
